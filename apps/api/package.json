    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.0",
